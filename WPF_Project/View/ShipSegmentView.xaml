                <Label Content="Date of Production" Style="{StaticResource TextManipulator}" Grid.Column="1" Grid.Row="2"/>
                <DatePicker Grid.Column="1" Grid.Row="3" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.75*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>


            <Button Grid.Column="0" Height="50" Width="150" Content="SAVE" Background="DarkSlateGray" FontSize="30" Foreground="White" BorderBrush="White"/>

            <ComboBox Grid.Column="1" Height="40" Width="200">
                <ComboBoxItem Content="Fuel Segment" />
                <ComboBoxItem Content="Passenger Segment"/>
                <ComboBoxItem Content="Storage Segment"/>
                <ComboBoxItem Content="Research Segment"/>
                <ComboBoxItem Content="Military Segment"/>
                <ComboBoxItem Content="Colonization Segment"/>
                <ComboBoxItem Content="Other Segment"/>
            </ComboBox>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.75*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Height="50" Width="150" Content="SAVE" Background="DarkSlateGray" FontSize="30" Foreground="White" BorderBrush="White"/>

            <ComboBox Grid.Column="1" Height="40" Width="200">
                <ComboBoxItem Content="Fuel Segment" />
                <ComboBoxItem Content="Passenger Segment"/>
