                </ComboBox>

                <Label Content="Date of Production" Style="{StaticResource TextManipulator}" Grid.Column="1" Grid.Row="2"/>
                <DatePicker Grid.Column="1" Grid.Row="3" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="Segment Specyfication" Grid.Row="0" Grid.Column="1" Foreground="White" Margin="5,5,5,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Label Content="Cargo" Style="{StaticResource TextManipulator}"/>

                <ComboBox Grid.Column="0" Grid.Row="1" Height="25" Width="200">
